# Copy to .env to override any defaults: cp .env.example .env
# All variables are optional — docker-compose.yml ships with sane defaults.

# ---------- Collection app ----------
COLLECTION_DB_USER=postgres
COLLECTION_DB_PASSWORD=postgres
COLLECTION_DB_NAME=courier_collection
COLLECTION_DB_PORT=5432           # host port -> collection-db:5432
COLLECTION_SERVER_PORT=5000       # host port -> collection-server:5000
COLLECTION_CLIENT_PORT=3000       # host port -> collection-client:80
# URL the BROWSER uses to reach the collection API (baked into the client build):
COLLECTION_API_PUBLIC_URL=http://localhost:5000/api

# ---------- Logistics app ----------
LOGISTICS_DB_USER=postgres
LOGISTICS_DB_PASSWORD=postgres
LOGISTICS_DB_NAME=courier_logistics
LOGISTICS_DB_PORT=5433            # host port -> logistics-db:5432
LOGISTICS_SERVER_PORT=5001        # host port -> logistics-server:5001
LOGISTICS_CLIENT_PORT=3001        # host port -> logistics-client:80
LOGISTICS_API_PUBLIC_URL=http://localhost:5001/api

# ---------- Shared ----------
JWT_SECRET=change_me_in_production
